{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --omit=dev && cd client && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "node index.js",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 25
  }
}
