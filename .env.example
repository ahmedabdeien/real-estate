# ─── Backend (Railway) ────────────────────────────────────────────────────────
MONGO="mongodb+srv://USER:PASS@cluster.mongodb.net/elsarh?retryWrites=true&w=majority"
JWT_SECRET="change_this_to_a_long_random_string"
NODE_ENV="production"
PORT=3000

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS="https://your-app.vercel.app,https://yourdomain.com"

# Firebase (server-side verification)
FIREBASE_PROJECT_ID="elsarh-real-estate"

# Email (optional)
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_app_password"

# ─── Frontend (Vercel env vars — set in Vercel dashboard) ────────────────────
# Full URL to Railway backend API (no trailing slash)
VITE_API_URL="https://your-backend.up.railway.app/api"

VITE_CLOUDINARY_CLOUD_NAME="your_cloud_name"
VITE_CLOUDINARY_UPLOAD_PRESET="elsarh_unsigned"

VITE_FIREBASE_API_KEY="..."
VITE_FIREBASE_AUTH_DOMAIN="elsarh-real-estate.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="elsarh-real-estate"
VITE_FIREBASE_STORAGE_BUCKET="elsarh-real-estate.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="..."
VITE_FIREBASE_APP_ID="..."
